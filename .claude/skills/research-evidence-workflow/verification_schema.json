{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "verdict",
    "reason",
    "required_fixes",
    "claim_results"
  ],
  "properties": {
    "verdict": {
      "type": "string",
      "enum": [
        "ACCEPTED",
        "DENIED"
      ]
    },
    "reason": {
      "type": "string"
    },
    "required_fixes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "claim_results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "claim_id",
          "status",
          "confidence",
          "notes"
        ],
        "properties": {
          "claim_id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "verified",
              "rejected",
              "needs_more_evidence",
              "unverified"
            ]
          },
          "confidence": {
            "type": "string",
            "enum": [
              "high",
              "medium",
              "low"
            ]
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
